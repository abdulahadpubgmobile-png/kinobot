BOT_TOKEN=your_bot_token_here

# Adminlar telegram ID lari (vergul bilan ajrating)
ADMINS=123456789,987654321

# Database URL
# SQLite (lokal uchun): sqlite+aiosqlite:///./kinobot.db
# PostgreSQL (Render uchun): postgresql+asyncpg://user:password@host:port/dbname
# Renderda DATABASE_URL avtomatik qo'shiladi, shuning uchun bo'sh qoldiring
DB_URL=sqlite+aiosqlite:///./kinobot.db

# Majburiy obuna kanallari (vergul bilan ajrating)
CHANNELS=-1001234567890,-1009876543210
